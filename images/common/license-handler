#!/bin/bash

## region ########################################### Functions

# @description Function to extract the repository name from a GitHub or GitLab URL
# @arg $1 string URL
# @stdout Repo Name
extract_repo_name() {
  local url="$1"
  if [[ "$url" =~ github\.com/([^/]+)/([^/]+)$ ]]; then
    echo "${BASH_REMATCH[2]}"
  elif [[ "$url" =~ gitlab\.com/([^/]+)/([^/]+)$ ]]; then
    echo "${BASH_REMATCH[2]}"
  else
    echo ""
  fi
}

# @description Parses licencecheck output to extract the copyright
# @arg $1 string Output from licensecheck
# @stdout string Copyright
function lc-copyright() {
  echo "$1" | grep -i "copyright" | head -n 1 | sed 's/Copyright://g' | sed 's/copyright://g' | sed 's/  */ /g' | sed 's/^ *//g' | sed 's/ *$//g'
}

# @description Parses licencecheck output to extract the Upstream Contact
# @arg $1 string Output from licensecheck
# @stdout string Upstream Contact
function lc-upstream-contact() {
  local upstreamContact ucName ucEmail
  upstreamContact=$(echo "$1" | grep "Upstream-Contact: " | awk -F': ' '{ print $2 }')
  if [ -z "$upstreamContact" ] && [ -n "$2" ]; then
    ucName=$(echo "$2" | grep -oP '(?<=[0-9[:punct:]])\s*\K[^<]+(?=\s<)' | xargs)
    ucEmail=$(echo "$2" | grep -oP '(?<=<)[^>]+(?=>)')
    if [ -n "$ucName" ] && [ -n "$ucEmail" ]; then
      upstreamContact="$ucName <$ucEmail>"
    fi
  fi

  echo "$upstreamContact"
}

# @description Parses licencecheck output to extract the short license string
# @arg $1 string Output from licensecheck
# @stdout string Short License String
function lc-license-short() {
  echo "$licenseContent" | grep "License: " | head -n | awk -F': ' '{ print $2 }'
}

# @description Parses license text looking for a copyright notice
# @arg $1 string License Text
# @stdout string Copyright
function parse-copyright() {
  echo "$1" | grep -E "^\s+\**(c|C)opyright" | xargs | grep -v "copyright notice" | sed 's/\*\*//g'
}

# @description Parses license text to identify the short license type
# @arg $1 string License Text
# @stdout string License Short
function parse-license-short() {
  local license_content licenseShort

  license_content="$1"
  if echo "$license_content" | grep -qi "Apache License" && echo "$license_content" | grep -qi "Version 2.0"; then
    licenseShort="Apache-2.0"
  elif echo "$license_content" | grep -qi "GNU General Public License, version 2" || echo "$license_content" | grep -qi "GPL v2"; then
    # DEP-5 uses 'GPL-2' or 'GPL-2+'
    licenseShort="GPL-2"
  elif echo "$license_content" | grep -qi "GNU General Public License, version 3"; then
    licenseShort="GPL-3"
  elif echo "$license_content" | grep -qi "GNU Lesser General Public License"; then
    licenseShort="LGPL-2.1" # or LGPL-3 depending on text
  elif echo "$license_content" | grep -qi "Expat" || echo "$license_content" | grep -qi "Permission is hereby granted, free of charge"; then
    # DEP-5 specifically prefers 'Expat' over 'MIT' for the standard MIT license
    licenseShort="Expat"
  elif echo "$license_content" | grep -qi "BSD 3-Clause License" || echo "$license_content" | grep -qi "3-clause BSD"; then
    licenseShort="BSD-3-clause"
  elif echo "$license_content" | grep -qi "BSD 2-Clause License" || echo "$license_content" | grep -qi "2-clause BSD"; then
    licenseShort="BSD-2-clause"
  elif echo "$license_content" | grep -qi "Artistic License"; then
    licenseShort="Artistic"
  elif echo "$license_content" | grep -qi "Mozilla Public License"; then
    licenseShort="MPL-2.0"
  else
    licenseShort="UNKNOWN"
  fi

  echo "$licenseShort"
}

# @description Parses copyright notice looking for an upstream contact
# @arg $1 string License Text
# @stdout string Upstream Contact
function parse-upstream-contact() {
  echo "$1" | sed 's/(c) //i'| sed 's/© //' | sed 's/copyright//i' | sed -e 's/^[[:space:]]*//g' | sed -E 's/^[0-9\-]+ //' | awk -F'.' '{print $1}'
}

# @description Function to display usage information
# @stdout string Usage information
usage() {
  echo "Usage: $0 --source <SOURCE> --license <LICENSE_FILE> --files <FILE_PATTERN>"
  echo "  --source <SOURCE>          Upstream source (e.g., GitHub or GitLab repository URL)"
  echo "  --license <LICENSE_FILE>   Path to the LICENSE file"
  echo "  --files <FILE_PATTERN>     File pattern for which the copyright applies (e.g., '*')"
  exit 0
}

## endregion ######################################## Functions

## region ########################################### Input Handling

# Parse command-line arguments
while [[ "$#" -gt 0 ]]; do
  case $1 in
  --source)     sourceUrl="$2";     shift ;;
  --name)       upstreamName="$2";  shift ;;
  --license)    licenseFile="$2";   shift ;;
  --files)      filePattern="$2";   shift ;;
  -h|--help)    usage ;;
  *) echo "Unknown parameter passed: $1"; exit 1 ;;
  esac
  shift
done

# Check if required arguments are provided
if [ -z "$sourceUrl" ] || [ -z "$licenseFile" ] || [ -z "$filePattern" ]; then
  echo "Error: All required arguments must be provided."
  usage
fi

# Check if the LICENSE file exists
if [ ! -f "$licenseFile" ]; then
  echo "Error: LICENSE file $licenseFile does not exist."
  exit 1
fi

## endregion ######################################## Functions

## region ########################################### Main Code

# Extract the upstream name from the source URL
[ -z "$upstreamName" ] && upstreamName=$(extract_repo_name "$sourceUrl")

# Read the LICENSE file & parse with licensecheck
licenseContent=$(cat "$licenseFile")
licenseCheck=$(licensecheck --deb-machine "$licenseFile" | grep -v "UNLICENSED" | sort | uniq -c | sort -nr)

# Get Copyright
copyright=$(lc-copyright "$licenseCheck")
[ -z "$copyright" ] && copyright=$(parse-copyright "$licenseContent")

upstreamContact=$(lc-upstream-contact "$licenseCheck")
[ -z "$upstreamContact" ] && [ -n "$copyright" ] && upstreamContact=$(parse-upstream-contact "$copyright")

# Get Short License
licenseShort=$(lc-license-short "$licenseCheck")
[ -z "$licenseShort" ] && licenseShort=$(parse-license-short "$licenseContent")

# Fallback for Copyright
[ -z "$copyright" ] && copyright="$sourceUrl"

# Create the copyright file
echo "Format: https://www.debian.org/doc/packaging-manuals/copyright-format/1.0/"
[ -n "$upstreamName" ] && "Upstream-Name: $upstreamName"
[ -n "$upstreamContact" ] && echo "Upstream-Contact: "
echo "Source: $sourceUrl"
echo ""
[ -n "$filesPattern" ] && echo "Files: $filePattern"
echo "Copyright: $COPYRIGHT_HOLDER"
echo "License: $licenseShort"
echo ""
echo "$licenseContent"
exit 0

